{
    "info": {
        "_postman_id": "brello-hrms-collection-v1",
        "name": "Brello HRMS API",
        "description": "Complete API collection for the Brello HRMS multi-tenant, multi-app backend.\n\n## Setup\n1. Set the `base_url` variable to your server address (default: `http://localhost:8000`)\n2. Start with the **Login** request to get tokens\n3. Tokens are auto-saved to collection variables for authenticated requests\n\n## Authentication Flow\n1. Login → saves `access_token` and `refresh_token`\n2. Use authenticated endpoints (token is auto-injected)\n3. Switch App → saves new `access_token`\n4. Refresh → rotates both tokens",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api/v1",
            "type": "string"
        },
        {
            "key": "access_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "refresh_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "enterprise_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "organization_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "user_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "default_app_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "app_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "role_id",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "description": "Authentication and authorization endpoints",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    const data = response.data;",
                                    "    pm.collectionVariables.set('access_token', data.access_token);",
                                    "    pm.collectionVariables.set('refresh_token', data.refresh_token);",
                                    "    pm.collectionVariables.set('user_id', data.user.id);",
                                    "    pm.collectionVariables.set('enterprise_id', data.user.enterprise_id);",
                                    "    pm.collectionVariables.set('organization_id', data.user.organization_id);",
                                    "    pm.collectionVariables.set('default_app_id', data.defaultAppId);",
                                    "    console.log('✅ Tokens saved. Default app:', data.defaultAppId);",
                                    "    console.log('Available apps:', JSON.stringify(data.availableApps));",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass@123\",\n    \"device_fingerprint\": \"postman-dev\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Authenticate with email and password.\n\n**Auto-saves:** `access_token`, `refresh_token`, `user_id`, `enterprise_id`, `organization_id`, `default_app_id` to collection variables."
                    },
                    "response": []
                },
                {
                    "name": "Switch App",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    pm.collectionVariables.set('access_token', response.data.access_token);",
                                    "    pm.collectionVariables.set('default_app_id', response.data.appId);",
                                    "    console.log('✅ Switched to app:', response.data.appId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"appId\": \"{{default_app_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/switch-app",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "switch-app"
                            ]
                        },
                        "description": "Switch to a different application. Provide the target `appId` (get available apps from the Login response).\n\n**Auto-saves:** New `access_token` scoped to the target app."
                    },
                    "response": []
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    pm.collectionVariables.set('access_token', response.data.access_token);",
                                    "    pm.collectionVariables.set('refresh_token', response.data.refresh_token);",
                                    "    console.log('✅ Tokens rotated successfully');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{refresh_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/auth/refresh",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "refresh"
                            ]
                        },
                        "description": "Refresh the access token using the refresh token.\n\n**Important:** Uses the `refresh_token` (not access_token) as the Bearer token.\n\n**Auto-saves:** New `access_token` and `refresh_token` (token rotation)."
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/auth/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "logout"
                            ]
                        },
                        "description": "Invalidate the current session. Returns 204 No Content."
                    },
                    "response": []
                },
                {
                    "name": "Update Password",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"old_password\": \"SecurePass@123\",\n    \"new_password\": \"NewSecurePass@456\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/update-password",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "update-password"
                            ]
                        },
                        "description": "Change the authenticated user's password.\n\n**Side effect:** All active sessions are invalidated (user must re-login).\n\n**Password rules:** Min 8 chars, must contain: uppercase, lowercase, digit, special character."
                    },
                    "response": []
                },
                {
                    "name": "Forgot Password (Request OTP)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john.doe@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/forgot-password",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "forgot-password"
                            ]
                        },
                        "description": "Request a password reset OTP. Always returns 204 (even if email doesn't exist, for security).\n\n**In dev mode:** Check the server console for the OTP log."
                    },
                    "response": []
                },
                {
                    "name": "Verify OTP & Reset Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"otp\": \"123456\",\n    \"new_password\": \"NewSecurePass@789\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/verify-otp",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "verify-otp"
                            ]
                        },
                        "description": "Verify the OTP received via email and set a new password.\n\n**OTP rules:** Exactly 6 digits, max 5 attempts, expires in 10 minutes."
                    },
                    "response": []
                }
            ]
        },
